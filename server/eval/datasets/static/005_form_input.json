{
  "id": "form_input_type_action",
  "description": "검색창에 텍스트 입력 + 검색 버튼 클릭 시퀀스. 직접 search URL navigate도 허용. 도착 후 type+click 시퀀스도 허용.",
  "query": "네이버에서 '날씨' 검색해줘",
  "url": "https://www.naver.com",
  "elements": [
    {
      "tag": "input",
      "text": "",
      "aria_label": "검색",
      "placeholder": "검색어를 입력하세요",
      "xpath": "/html/body/main/form/input[1]",
      "type": "text",
      "name": "query"
    },
    {
      "tag": "button",
      "text": "검색",
      "xpath": "/html/body/main/form/button[1]",
      "type": "submit"
    }
  ],
  "expected": {
    "needs_more_elements": false,
    "acceptable_action_sequences": [
      [
        {"type": "type", "xpath": "/html/body/main/form/input[1]", "value_contains": "날씨"},
        {"type": "click", "xpath": "/html/body/main/form/button[1]"}
      ],
      [
        {"type": "navigate", "url_contains": "search.naver.com", "url_must_contain_query": "날씨"}
      ],
      [
        {"type": "navigate", "url_contains": "naver.com"},
        {"type": "type", "value_contains": "날씨"},
        {"type": "click"}
      ]
    ],
    "must_not_click_xpaths": [],
    "must_highlight_only": []
  }
}
