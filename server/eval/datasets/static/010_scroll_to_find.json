{
  "id": "scroll_or_click_link",
  "description": "푸터 이용약관 링크 — click(xpath) / click_text / navigate(href) 모두 정답",
  "query": "이용약관 보고싶어",
  "url": "https://example.com",
  "elements": [
    {
      "tag": "a",
      "text": "이용약관",
      "xpath": "/html/body/footer/a[1]",
      "href": "/terms"
    },
    {
      "tag": "a",
      "text": "개인정보처리방침",
      "xpath": "/html/body/footer/a[2]",
      "href": "/privacy"
    }
  ],
  "expected": {
    "needs_more_elements": false,
    "acceptable_action_sequences": [
      [{"type": "click", "xpath": "/html/body/footer/a[1]"}],
      [{"type": "click_text", "text": "이용약관"}],
      [{"type": "navigate", "url_contains": "/terms"}]
    ],
    "must_not_click_xpaths": [],
    "must_highlight_only": []
  }
}
