{
  "manifest_version": 3,
  "name": "DOM Semantic Navigator",
  "version": "0.1.0",
  "description": "자연어로 웹사이트를 조작하는 AI 도우미 (DOM 기반 의미 검색)",
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "webNavigation"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["config.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },
  "action": {
    "default_title": "DOM Navigator 열기"
  }
}
